package P7_Dita;

import java.util.Scanner;

public class Latihan {

    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);
        
        final float TOTAL_PERTEMUAN = 21;
        float syaratMinimalMasuk = TOTAL_PERTEMUAN * 0.75f; 
        
        System.out.println("=== Sistem Penilaian Mahasiswa ===");
        
        System.out.print("Masukkan total kehadiran mahasiswa: ");
        float kehadiran = input.nextFloat();

        System.out.print("Masukkan skor nilai akhir: ");
        float nilai = input.nextFloat();
        
        System.out.println("\n--- Hasil Evaluasi ---");
        
        if (kehadiran >= syaratMinimalMasuk) {
            String grade = ""; 
            
            if (nilai >= 85) {
                grade = "A (Istimewa)";
            } else if (nilai >= 75) {
                grade = "B (Sangat Baik)";
            } else if (nilai >= 65) {
                grade = "C (Cukup)";
            } else if (nilai >= 50) {
                grade = "D (Kurang)";
            } else {
                grade = "E (Gagal)";
            }
            
            System.out.println("Status Kehadiran : Memenuhi Syarat (" + kehadiran + " hari)");
            System.out.println("Nilai Kumulatif  : " + nilai);
            System.out.println("Grade Akhir      : " + grade);
            
        } else {
            // Jika kehadiran di bawah 75%
            System.out.println("Status: TIDAK LULUS");
            System.out.println("Alasan: Persentase kehadiran kurang dari 75% (Minimal: " + syaratMinimalMasuk + " hari).");
        }
        
        input.close();
    }
}
